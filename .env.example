# Copy to `.env` and fill in your football-data.org key.
# Free key at https://www.football-data.org/client/register — no cost, no card.
#
# WARNING: VITE_-prefixed vars are bundled into the client and visible in
# production. Use this only for local dev. For deploys, put the key behind
# a proxy and drop the VITE_ prefix.

VITE_FOOTBALL_DATA_KEY=your_key_here

# WC = FIFA World Cup. Free tier supports it.
VITE_FOOTBALL_DATA_COMPETITION=WC
