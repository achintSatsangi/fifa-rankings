# Local-only env used by `scripts/refresh-live.mjs`. This file is a
# template — copy to `.env` (gitignored) and fill in your key.
#
# The app itself no longer reads any env vars — the refresh script
# updates the bundled JSON files, which are the only data source at
# runtime. In CI the same key is provided via the FOOTBALL_DATA_KEY
# repo secret (see .github/workflows/refresh-and-deploy.yml).

FOOTBALL_DATA_KEY=your_key_here

# Optional; defaults to WC (FIFA World Cup) if unset.
FOOTBALL_DATA_COMPETITION=WC
